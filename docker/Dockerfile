# Используем официальный образ Alpine последней версии
FROM alpine:latest

# Устанавливаем необходимые зависимости
RUN apk update && apk add --no-cache \
    bash \
    tar \
    gzip \
    gfortran \
    netcdf-fortran-dev \
    build-base \
    && rm -rf /var/cache/apk/*

# Создаём рабочую директорию для программы
WORKDIR /app

# Копируем програму из контекста сборки в контейнер
COPY mopsmap/ ./mopsmap

# Переходим в директорию с распакованной программой
WORKDIR /app/mopsmap

# Компилируем программу, если это необходимо (зависит от структуры архива)
# Обычно в программах на Fortran есть Makefile
RUN make || true

# Проверяем, есть ли исполняемый файл, и делаем его исполняемым
# Замените "mopsmap" на имя вашего основного исполняемого файла, если оно другое
RUN chmod +x ./mopsmap || true

# Указываем команду для запуска программы по умолчанию
CMD ["./mopsmap"]
